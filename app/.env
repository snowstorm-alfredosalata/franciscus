# Public build-time config for the GitHub contribution flow. All values are
# public by construction (client id, worker origin, upstream repo) and are baked
# into the static bundle via SvelteKit's `$env/static/public`. No secrets here —
# the OAuth client secret lives only in the Cloudflare Worker.
PUBLIC_GH_CLIENT_ID=Iv23liUYOiH6aSzkICg2
PUBLIC_AUTH_WORKER_ORIGIN=https://franciscus-auth.as-be3.workers.dev
PUBLIC_DATA_REPO=FranciscusApp/franciscus-data
